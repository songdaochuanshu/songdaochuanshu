#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")
basedir_win="$basedir"
exe=""
msys=""

case `uname -a` in
  *CYGWIN*|*MINGW*|*MSYS*)
    if command -v cygpath > /dev/null 2>&1; then
      basedir_win=`cygpath -w "$basedir"`
    fi
    exe=".exe"
    msys="true"
  ;;
  *WSL2*)
    if command -v wslpath > /dev/null 2>&1; then
      basedir_win="$(wslpath -w "$basedir" 2> /dev/null)"
      if [ $? -ne 0 ] || [ -z "$basedir_win" ]; then
        basedir_win="$basedir"
      else
        exe=".exe"
      fi
    fi
  ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/root/r2-blog/node_modules/.pnpm/nitropack@2.13.4_oxc-parser@0.133.0_srvx@0.11.17/node_modules/nitropack/node_modules:/root/r2-blog/node_modules/.pnpm/nitropack@2.13.4_oxc-parser@0.133.0_srvx@0.11.17/node_modules:/root/r2-blog/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/root/r2-blog/node_modules/.pnpm/nitropack@2.13.4_oxc-parser@0.133.0_srvx@0.11.17/node_modules/nitropack/node_modules:/root/r2-blog/node_modules/.pnpm/nitropack@2.13.4_oxc-parser@0.133.0_srvx@0.11.17/node_modules:/root/r2-blog/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -n "$exe" ] && [ -x "$basedir/node.exe" ]; then
  exec "$basedir/node.exe"  "$basedir_win/../../../../nitropack/dist/cli/index.mjs" "$@"
elif [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../../../../nitropack/dist/cli/index.mjs" "$@"
elif command -v node >/dev/null 2>&1; then
  exec node  "$basedir/../../../../nitropack/dist/cli/index.mjs" "$@"
elif [ -n "$exe" ] && command -v node.exe >/dev/null 2>&1; then
  exec node.exe  "$basedir_win/../../../../nitropack/dist/cli/index.mjs" "$@"
else
  exec node  "$basedir/../../../../nitropack/dist/cli/index.mjs" "$@"
fi
