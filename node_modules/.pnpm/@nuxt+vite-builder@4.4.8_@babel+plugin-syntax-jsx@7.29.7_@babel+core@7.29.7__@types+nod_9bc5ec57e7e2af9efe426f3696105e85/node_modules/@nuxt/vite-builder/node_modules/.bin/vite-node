#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")
basedir_win="$basedir"
exe=""
msys=""

case `uname -a` in
  *CYGWIN*|*MINGW*|*MSYS*)
    if command -v cygpath > /dev/null 2>&1; then
      basedir_win=`cygpath -w "$basedir"`
    fi
    exe=".exe"
    msys="true"
  ;;
  *WSL2*)
    if command -v wslpath > /dev/null 2>&1; then
      basedir_win="$(wslpath -w "$basedir" 2> /dev/null)"
      if [ $? -ne 0 ] || [ -z "$basedir_win" ]; then
        basedir_win="$basedir"
      else
        exe=".exe"
      fi
    fi
  ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/root/r2-blog/node_modules/.pnpm/vite-node@5.3.0_@types+node@22.19.21_jiti@2.7.0_terser@5.48.0_yaml@2.9.0/node_modules/vite-node/node_modules:/root/r2-blog/node_modules/.pnpm/vite-node@5.3.0_@types+node@22.19.21_jiti@2.7.0_terser@5.48.0_yaml@2.9.0/node_modules:/root/r2-blog/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/root/r2-blog/node_modules/.pnpm/vite-node@5.3.0_@types+node@22.19.21_jiti@2.7.0_terser@5.48.0_yaml@2.9.0/node_modules/vite-node/node_modules:/root/r2-blog/node_modules/.pnpm/vite-node@5.3.0_@types+node@22.19.21_jiti@2.7.0_terser@5.48.0_yaml@2.9.0/node_modules:/root/r2-blog/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -n "$exe" ] && [ -x "$basedir/node.exe" ]; then
  exec "$basedir/node.exe"  "$basedir_win/../../../../vite-node/dist/cli.mjs" "$@"
elif [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../../../../vite-node/dist/cli.mjs" "$@"
elif command -v node >/dev/null 2>&1; then
  exec node  "$basedir/../../../../vite-node/dist/cli.mjs" "$@"
elif [ -n "$exe" ] && command -v node.exe >/dev/null 2>&1; then
  exec node.exe  "$basedir_win/../../../../vite-node/dist/cli.mjs" "$@"
else
  exec node  "$basedir/../../../../vite-node/dist/cli.mjs" "$@"
fi
